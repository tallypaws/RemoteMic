{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 7070",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"ex:build": "tsc -p tsconfig.server.json",
		"ex:dev": "tsc -p tsconfig.server.json --watch",
		"ex:serve": "nodemon --watch serverOut  --enable-source-maps serverOut/server.js --proxy",
		"proxy": "node  --enable-source-maps serverOut/server.js --proxy",
		"start": "node  serverOut/server.js"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@thetally/httptree": "^0.3.0",
		"@thetally/toolbox": "^1.0.0",
		"@types/http-proxy": "^1.17.17",
		"@types/ws": "^8.18.1",
		"http-proxy": "^1.18.1",
		"mode-watcher": "^1.1.0",
		"ws": "^8.19.0"
	}
}
